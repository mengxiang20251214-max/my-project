# 应用密钥（生产环境必须修改）
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT 配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库（默认 SQLite）
DATABASE_URL=sqlite:///./blog_video.db

# 网站配置
SITE_NAME=VideoHub Pro
SITE_DESCRIPTION=专业视频博客平台
SITE_URL=http://localhost:8000

# 文件上传配置
UPLOAD_DIR=../static/uploads
MAX_UPLOAD_SIZE=524288000

# ── 存储后端：local（本地磁盘，默认） | r2（Cloudflare R2 对象存储）──────────────
STORAGE_BACKEND=local
# 切到 r2 时填下面这几项（在 Cloudflare R2 控制台获取）：
R2_BUCKET=video-blog-storage
R2_ENDPOINT=https://9692ca2edc2f9abcbacf0a7a6ba218ab.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-10c86c1e92b3432284fa82865c1edc1f.r2.dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# 管理员默认账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# 调试模式
DEBUG=True
